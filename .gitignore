# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
Thumbs.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Env and local secrets (keep `.env.example` committed as the template)
.env
.env.*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# caches & tooling
.turbo
.eslintcache
*.log

# IDE / editor (uncomment `.vscode/` if you never want shared editor config in git)
.idea/
*.swp
*.swo
*~

# Supabase CLI local scratch (if you use `supabase start` / link)
supabase/.temp/
